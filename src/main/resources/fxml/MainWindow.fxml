<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.drawboard.ui.MainWindowController"
            prefWidth="1200.0" prefHeight="800.0">

    <!-- Menu Bar -->
    <top>
        <VBox>
            <MenuBar>
                <Menu text="File">
                    <MenuItem text="New Notebook..." fx:id="menuNewNotebook" onAction="#handleNewNotebook"/>
                    <MenuItem text="Delete Notebook..." fx:id="menuDeleteNotebook" onAction="#handleDeleteNotebook" disable="true"/>
                    <SeparatorMenuItem/>
                    <Menu text="Import from...">
                        <MenuItem text="Obsidian Vault..." onAction="#handleImportObsidianVault"/>
                    </Menu>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit" onAction="#handleExit"/>
                </Menu>
                <Menu text="Edit">
                    <MenuItem text="Undo" disable="true"/>
                    <MenuItem text="Redo" disable="true"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Paste" onAction="#handlePaste" accelerator="Shortcut+V"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Find..." onAction="#handleSearch" accelerator="Shortcut+F"/>
                </Menu>
                <Menu text="View">
                    <CheckMenuItem text="Show Toolbar" selected="true" disable="true"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Preferences..." onAction="#handlePreferences"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About Drawboard" onAction="#handleAbout"/>
                </Menu>
            </MenuBar>

            <!-- Toolbar -->
            <ToolBar fx:id="toolbar">
                <Button text="New Notebook" fx:id="btnNewNotebook" onAction="#handleNewNotebook"
                        minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"/>
                <Button text="New Chapter" fx:id="btnNewChapter" onAction="#handleNewChapter" disable="true"
                        minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"/>
                <Button text="New Page" fx:id="btnNewPage" onAction="#handleNewPage" disable="true"
                        minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"/>
                <Separator orientation="VERTICAL"/>
                <Button text="Search" fx:id="btnSearch" onAction="#handleSearch"
                        minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"/>
                <Separator orientation="VERTICAL"/>
                <Label text="Tools:" style="-fx-padding: 0 10 0 10;"/>
                <ToggleButton text="Select" fx:id="btnSelectTool" onAction="#handleSelectTool" selected="true"
                              minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"/>
                <ToggleButton text="Text" fx:id="btnTextTool" onAction="#handleTextTool"
                              minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"/>
                <ToggleButton text="Pen" fx:id="btnPenTool" onAction="#handlePenTool"
                              minWidth="32" minHeight="32" maxWidth="32" maxHeight="32"/>
                <!-- Tool-specific settings container -->
                <HBox fx:id="toolSettingsContainer" spacing="5" style="-fx-padding: 0 0 0 5;"/>
            </ToolBar>
        </VBox>
    </top>

    <!-- Main Content Area -->
    <center>
        <SplitPane dividerPositions="0.2" fx:id="splitPane">
            <!-- Navigation (Left) -->
            <VBox spacing="5" style="-fx-padding: 5;" minWidth="150" prefWidth="250">
                <Label text="Notebook" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="notebookSelector" promptText="Select a notebook..." maxWidth="Infinity"/>
                <Label text="Chapters" style="-fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                    <Accordion fx:id="chapterAccordion"/>
                </ScrollPane>
            </VBox>

            <!-- Canvas Editor Area (Right) -->
            <StackPane fx:id="canvasArea" minWidth="400">
                <Label fx:id="placeholderLabel" text="Select a page to begin" style="-fx-text-fill: gray;"/>
            </StackPane>
        </SplitPane>
    </center>

    <!-- Status Bar -->
    <bottom>
        <HBox spacing="10" style="-fx-padding: 5; -fx-background-color: #f0f0f0;">
            <Label fx:id="statusLabel" text="Ready"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="pageInfoLabel" text=""/>
        </HBox>
    </bottom>

</BorderPane>
